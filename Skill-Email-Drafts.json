{
  "id": "com.company.email-drafts",
  "name": "Email Drafts (Draft only, no send)",
  "version": "1.0.0",
  "description": "Generates email drafts only. Does not access mailboxes or send messages.",
  "publisher": "Tarik",
  "entryPoint": "https://<your-host>/api/skill/execute",
  "actions": [
    {
      "id": "generateDrafts",
      "name": "Generate Drafts",
      "description": "Return subject, preview_text, and three draft variants as JSON.",
      "inputs": [
        { "name": "recipient_role", "type": "string", "required": true },
        { "name": "situation_summary", "type": "string", "required": true },
        { "name": "desired_outcome", "type": "string", "required": true },
        { "name": "tone", "type": "string", "required": false }
      ],
      "outputs": [
        { "name": "subject", "type": "string" },
        { "name": "preview_text", "type": "string" },
        { "name": "drafts", "type": "array" },
        { "name": "recommendation", "type": "string" }
      ]
    }
  ],
  "auth": {
    "type": "none"
  },
  "icons": {
    "16": "https://<your-host>/icons/16.png",
    "64": "https://<your-host>/icons/64.png"
  }
}